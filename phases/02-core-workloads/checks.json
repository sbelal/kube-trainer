    {
        "id": "pods-running",
        "title": "Pods with label app=hello-app are running",
        "type": "command",
        "command": "kubectl get pods -l app=hello-app --field-selector=status.phase=Running -o jsonpath='{.items[*].metadata.name}'",
        "expect": {
            "exitCode": 0,
            "outputMatches": "hello-app"
        },
        "fix": {
            "file": "05-hands-on-exercise.md",
            "section": "Step 4: Verify Pods Are Running"
        }
    },
    {
        "id": "rollout-history",
        "title": "Deployment has rollout history",
        "type": "command",
        "command": "kubectl rollout history deployment/hello-app",
        "expect": {
            "exitCode": 0,
            "outputContains": "REVISION"
        },
        "fix": {
            "file": "04-rolling-updates.md",
            "section": "Hands-On: Perform a Rolling Update"
